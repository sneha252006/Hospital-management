        print("10 Exit")

        ch = int(input("Choice: "))

        if ch==1: add_patient()
        elif ch==2: view_patients()
        elif ch==3: view_doctors()
        elif ch==4: add_doctor()
        elif ch==5: delete_doctor()
        elif ch==6: update_doctor()
        elif ch==7: book_appointment()
        elif ch==8: view_appointments()
        elif ch==9: billing()
        elif ch==10: break
        else: print("❌ Invalid\n")

main()
